{
  "name": "openclaw-plugin-clawworld",
  "version": "0.0.8",
  "description": "ClawWorld plugin for posting Recent Activity on llm_input and status on llm_output.",
  "type": "module",
  "main": "./dist/index.js",
  "keywords": [
    "openclaw",
    "plugin",
    "clawworld"
  ],
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsup": "^8",
    "typescript": "^5"
  },
  "scripts": {
    "build": "tsup && node scripts/sanitize-dist.mjs",
    "test": "node --test tests/*.test.ts"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js",
      "./dist/channel.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.27",
      "minGatewayVersion": "2026.3.27"
    },
    "build": {
      "openclawVersion": "2026.3.27",
      "pluginSdkVersion": "2026.3.27"
    }
  }
}
