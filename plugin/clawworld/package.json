{
  "name": "openclaw-plugin-clawworld",
  "version": "0.0.7",
  "description": "ClawWorld plugin for posting Recent Activity on llm_input and status on llm_output.",
  "type": "module",
  "main": "./index.ts",
  "keywords": [
    "openclaw",
    "plugin",
    "clawworld"
  ],
  "dependencies": {
    "@types/ws": "^8.18.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "openclaw": "2026.3.27"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.27"
  },
  "scripts": {
    "test": "node --test tests/*.test.ts"
  },
  "openclaw": {
    "extensions": [
      "./index.ts",
      "./channel.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.27",
      "minGatewayVersion": "2026.3.27"
    },
    "build": {
      "openclawVersion": "2026.3.27",
      "pluginSdkVersion": "2026.3.27"
    }
  }
